generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String     @id @default(uuid())
  name       String
  email      String     @unique
  phone      String?
  avatar     String?
  password   String?
  role       UserRole   @default(client)
  businesses Business[]
  bookings   Booking[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

enum UserRole {
  client
  owner
  admin
}

model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String?
  icon        String?
  color       String?
  order       Int        @default(0)
  businesses  Business[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Business {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  description String?
  logoUrl     String?
  coverUrl    String?
  address     String?
  city        String?
  province    String?
  contact     String?
  phone       String?
  email       String?
  website     String?
  rating      Float       @default(0)
  reviewCount Int         @default(0)
  minPrice    Float?
  isActive    Boolean     @default(true)
  isFeatured  Boolean     @default(false)
  tag         String?
  bookingMode BookingMode @default(hourly)
  category    Category    @relation(fields: [categoryId], references: [id])
  categoryId  String
  owner       User?       @relation(fields: [ownerId], references: [id])
  ownerId     String?
  resources   Resource[]
  bookings    Booking[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Resource {
  id          String    @id @default(uuid())
  name        String
  description String?
  type        String?
  price       Float?
  duration    Int?
  capacity    Int?
  isActive    Boolean   @default(true)
  business    Business  @relation(fields: [businessId], references: [id])
  businessId  String
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Booking {
  id            String        @id @default(uuid())
  customerName  String
  customerEmail String
  customerPhone String?
  notes         String?
  business      Business      @relation(fields: [businessId], references: [id])
  businessId    String
  resource      Resource      @relation(fields: [resourceId], references: [id])
  resourceId    String
  user          User?         @relation(fields: [userId], references: [id])
  userId        String?
  date          DateTime
  endDate       DateTime?
  startTime     DateTime?
  endTime       DateTime?
  mode          BookingMode
  totalAmount   Float         @default(0)
  depositAmount Float         @default(0)
  paidAmount    Float         @default(0)
  paymentStatus PaymentStatus @default(pending)
  status        BookingStatus @default(pending)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum BookingMode {
  hourly
  appointment
  daily
  range
}

enum PaymentStatus {
  pending
  paid
  partial
}

enum BookingStatus {
  pending
  confirmed
  deposited
  paid
  cancelled
  completed
}
